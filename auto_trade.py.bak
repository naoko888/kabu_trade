# =========================
# グローバル状態
# =========================
token    = None
position = None
day_pnl  = 0
consec_loss = 0
trade_log   = []
signal_log  = []
consecutive_auth_errors = 0
MAX_AUTH_ERRORS  = 5
last_reauth_time = 0
REAUTH_COOLDOWN  = 10

# 1570 5分足
current_bar    = None
completed_bars = []
last_cum_volume = None
last_price      = None
last_signal_bar_time = None

# 1570 DRY
dry_position  = None
dry_day_pnl   = 0
dry_trade_log = []

